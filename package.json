{
  "name": "pilotswarm",
  "version": "0.1.0",
  "description": "A durable execution runtime for GitHub Copilot SDK agents. Crash recovery, durable timers, session dehydration, and multi-node scaling — powered by duroxide.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pilotswarm-tui": "./bin/tui.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --env-file=.env test/sdk.test.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "chat": "node --env-file=.env examples/chat.js",
    "tui": "node bin/tui.js local --env .env.remote",
    "tui:remote": "node bin/tui.js remote --env .env.remote",
    "worker": "node --env-file=.env.remote examples/worker.js",
    "docker:build": "npm run build && docker build -f deploy/Dockerfile.worker -t pilotswarm-worker:latest .",
    "docker:push": "docker tag pilotswarm-worker:latest 794267021535.dkr.ecr.us-east-1.amazonaws.com/pilotswarm-worker:latest && docker push 794267021535.dkr.ecr.us-east-1.amazonaws.com/pilotswarm-worker:latest",
    "ecs:deploy": "bash deploy/ecs/deploy.sh",
    "ecs:logs": "aws logs tail /ecs/pilotswarm-worker --follow --region us-east-1",
    "ecs:status": "aws ecs describe-services --cluster pilotswarm --services pilotswarm-worker --region us-east-1 --query 'services[0].{status:status,running:runningCount,desired:desiredCount,task:taskDefinition}'",
    "test:s3": "node --env-file=.env scripts/test-s3.js",
    "test:s3:hydration": "node --env-file=.env scripts/test-s3-hydration.js",
    "db:reset": "node --env-file=.env scripts/db-reset.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "copilot",
    "durable",
    "duroxide",
    "agent",
    "orchestration",
    "async"
  ],
  "author": "Affan Dar",
  "license": "MIT",
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@bradygaster/squad-cli": "^0.8.25",
    "@github/copilot": "^1.0.2",
    "@github/copilot-sdk": "^0.1.32",
    "chalk": "^5.6.2",
    "duroxide": "^0.1.14",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "neo-blessed": "^0.1.81",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist/**/*",
    "bin/**/*",
    "cli/tui.js",
    "plugin/**/*",
    "README.md"
  ]
}
