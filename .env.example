# ─── Model Providers ──────────────────────────────────────────────
# Configure LLM providers in model_providers.json (see model_providers.example.json).
# API keys are referenced via env:VAR_NAME syntax — store the actual keys here.
#
# GitHub Copilot (requires a GitHub token with Copilot access):
GITHUB_TOKEN=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
#
# Azure OpenAI:
# AZURE_OPENAI_KEY=your-azure-openai-key
#
# OpenAI:
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Anthropic:
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Legacy: You can still use these env vars directly (without model_providers.json):
# LLM_ENDPOINT=https://my-resource.openai.azure.com/openai
# LLM_API_KEY=your-api-key
# LLM_PROVIDER_TYPE=azure
# LLM_API_VERSION=2024-10-21
# LLM_MODELS=gpt-4.1-mini,gpt-4.1
# COPILOT_MODEL=gpt-4.1-mini

# ─── Duroxide Store (database) ────────────────────────────────────
# Required. PostgreSQL connection string for duroxide orchestration + CMS.
# For local development, run Postgres in Docker:
#   docker run -d --name durable-pg -p 5432:5432 \
#     -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=durable_copilot \
#     postgres:16
DATABASE_URL=postgresql://postgres:admin@localhost:5432/pilotswarm

# For quick testing without Postgres, use SQLite (in-memory):
# DATABASE_URL=sqlite::memory:

# ─── Azure Blob Storage (optional) ───────────────────────────────
# Optional. Used for session dehydration/hydration (long waits, pod relocation).
# Not needed for local dev or single-process mode.
# Create a storage account + container in Azure, then paste the connection string.
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=copilot-sessions
